{
  "name": "uBUNtu",
  "image": "ghcr.io/iamvikshan/devcontainer/agents:latest",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1.10.0": {
      "moby": false,
      "installDockerBuildx": true
    }
  },
  "mounts": ["source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"],
  "runArgs": ["--network=host"],
  "forwardPorts": [20128],
  "portsAttributes": {
    "20128": {
      "label": "omniroute",
      "onAutoForward": "notify",
      "visibility": "private"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "oxc.oxc-vscode",
        "oven.bun-vscode",
        "ms-azuretools.vscode-docker",
        "coderabbit.coderabbit-vscode",
        "WakaTime.vscode-wakatime",
        "docker.docker"
      ]
    }
  },
  "remoteUser": "root",
  "postCreateCommand": "bun bs --default",
  "postStartCommand": "bun omni"
}
