{
  "name": "Alpine Bun",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    // uncomment the following lines to install common-utils
    // 		"ghcr.io/devcontainers/features/common-utils:latest": {
    // 	"username": "root",
    // 	"upgradePackages": "true"
    // },
    // git is preinstalled in the bun image
  },

  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "zsh"
          }
        },
        "terminal.integrated.defaultProfile.linux": "zsh"
      },
      "extensions": ["GitHub.copilot", "eamodio.gitlens", "oven.bun-vscode", "oxc.oxc-vscode"]
    }
  },

  // Use 'postCreateCommand' to run commands after the container is created.
  "postCreateCommand": "bun install",

  // Set `remoteUser` to `root` to connect as root.
  "remoteUser": "root"
}
